LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

OPENEMR_BASE_URL=https://openemr-production-c5b4.up.railway.app
OPENEMR_FHIR_BASE=https://openemr-production-c5b4.up.railway.app/apis/default/fhir
OPENEMR_FHIR_TOKEN=

USE_FIXTURE_FHIR=1

SMART_CLIENT_ID=
SMART_CLIENT_SECRET=
SMART_REDIRECT_URI=http://localhost:8000/smart/callback
SMART_SCOPES=launch openid fhirUser patient/*.read offline_access

CHECKPOINTER_DSN=

# AES-256 key for token-bundle encryption at rest. Required when
# CHECKPOINTER_DSN is set; the agent fails to start otherwise.
# Generate: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# See agentforge-docs/TOKEN-ENCRYPTION.md.
COPILOT_TOKEN_ENC_KEY=

AGENT_AUDIT_LOG_PATH=./logs/agent_audit.jsonl

LOG_LEVEL=INFO

# Langfuse self-hosted (see EVAL.md §5). Empty values disable Langfuse;
# evals still run locally and print results to stdout.
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PROJECT=copilot

# Eval-only knobs.
EVAL_EXPERIMENT_NAME=
EVAL_FAIL_FAST=0
