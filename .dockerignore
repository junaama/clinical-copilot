# Repo-root .dockerignore — applies when build context is the repo root
# (see scripts/deploy-agent.sh + agent/railway.toml). Keep the context lean:
# only agent/ and copilot-ui/ source need to be uploaded.

# Python virtualenvs / build artifacts
**/.venv
**/.venv-*
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache
**/*.egg-info
**/build/
**/dist/

# Node
**/node_modules

# Local secrets — never bake into images
**/.env
**/.env.*
!**/.env.example

# Local-only data
**/logs/

# Tooling / VCS
.git
.gitignore
.editorconfig
**/.python-version

# Docs and tests not needed at runtime
**/README.md
**/tests/
**/evals/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Other top-level dirs not needed for the agent image
agentforge-docs/
issues/
docker/
docker-compose.yml
docker-compose-easy-dev-tests.yml
phpunit.xml*
.github/

# OpenEMR PHP tree — not needed for the agent build (agent + copilot-ui only)
library/
interface/
vendor/
src/
public/
sql/
contrib/
ccdaservice/
modules/
templates/
custom/
controllers/
apis/
oauth2/
portal/
sphere/
swagger/
Documentation/
gacl/
ci/
config/
db/
infra/
meta/
sites/
tools/
bin/
cli/
sphere/
node_modules/
*.php
*.phtml
phpcs.xml*
phpstan.neon*
rector.php
rector-bootstrap.php
rector-globals.php
package.json
package-lock.json
composer.json
composer.lock
gulpfile.js
eslint.config.mjs
jest.config.js
build.xml
cloudbuild.yaml
codecov.yml
semgrep.yaml
*.csv
skills-lock.json
docker-version
robots.txt
acknowledge_license_cert.html

# Keep agent/ and copilot-ui/ even though some patterns above might match
!agent/
!copilot-ui/
!agent/**
!copilot-ui/**
