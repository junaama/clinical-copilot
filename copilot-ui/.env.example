# Base URL for the Python LangGraph agent service.
# In dev (npm run dev) leave this blank — vite proxies /api → http://localhost:8000.
# In prod set to the public agent URL, e.g. https://copilot-agent.example.com
VITE_AGENT_URL=

# Base URL for the OpenEMR FHIR R4 server. Used for SMART discovery / token exchange
# (the actual exchange happens server-side via the agent; this URL is informational
# for the UI's SMART scaffold).
VITE_FHIR_BASE=https://openemr-production-c5b4.up.railway.app/apis/default/fhir
